{
  "expo": {
    "name": "Krushi Express",
    "slug": "krushi-express",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Krushi.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "krushiexpress",
    "splash": {
      "image": "./assets/images/Krushi.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Krushi.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/Krushi.png"
    },
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      
      "SOCKET_IO_URL": "http://192.168.12.81:5000",
      "API_BASE_URL": "http://192.168.12.81:5000",
      "CLOUDINARY_CLOUD_NAME": "dvzg4pod2"
    }
  }
}
