{
  "expo": {
    "name": "Krushi Express",
    "slug": "krushi-express",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Krushi.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "krushiexpress",
    "splash": {
      "image": "./assets/images/Krushi.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Krushi.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "package": "com.prasad_rathod_3.krushiexpress"
    },
    "web": {
      "favicon": "./assets/images/Krushi.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Krushi Express to use your location for booking rides."
        }
      ],
      "@rnmapbox/maps"
    ],
    "extra": {
      "API_BASE_URL": "https://krushi-express-backend.onrender.com",
      "SOCKET_IO_URL": "https://krushi-express-backend.onrender.com",
      "MAPBOX_TOKEN": "pk.eyJ1Ijoia3J1c2hpLWV4cHJlc3MtbWgyNCIsImEiOiJjbWRlcmoxb2QwNTVuMmxxeHR0eGw0eHB5In0.LS-wjw8x8SVqBX9siWigvQ",
      "CLOUDINARY_CLOUD_NAME": "dvzg4pod2",
      "eas": {
        "projectId": "9bb3c471-2a5a-41d9-ab14-16ec464652d0"
      }
    },
    "owner": "prasad_rathod_3"
  }
}
